# ─── AI Provider Configuration ───────────────────────────────────────────────
# Choose one of: openai | anthropic | gemini
PROVIDER=openai

# Model name for the chosen provider.
# Cheap/fast defaults (verify current model names before use):
#   OpenAI:    gpt-4o-mini
#   Anthropic: claude-haiku-3-5 (or latest claude-3-haiku)
#   Gemini:    gemini-1.5-flash
MODEL=gpt-4o-mini

# ─── API Keys (fill in only the one you use) ──────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./db/bracha_app.db

# ─── Sefaria ──────────────────────────────────────────────────────────────────
# Sefaria is a free public API; no key required.
# Rate-limit delay between requests (seconds):
SEFARIA_DELAY=1.0

# ─── Backend ──────────────────────────────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
